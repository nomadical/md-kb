{
  "name": "@skycell-ag/kb-react",
  "version": "0.3.0",
  "description": "Embeddable, read-only SkyCell Knowledge Base widgets for React hosts (direct-to-Supabase via Keycloak-JWT third-party auth, RLS-scoped).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyCell-AG/knowledge-base-app.git",
    "directory": "packages/kb-react"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.107.0",
    "react-markdown": "9.0.1",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.0"
  },
  "peerDependencies": {
    "@mui/material": ">=5",
    "@mui/icons-material": ">=5",
    "@skycell-ag/scd-lib": ">=1.7.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@skycell-ag/scd-lib": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mui/material": "^7",
    "@mui/icons-material": "^7",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@skycell-ag/kb-core": "*",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "oxlint": "^1",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5.7",
    "vite": "^7"
  }
}
