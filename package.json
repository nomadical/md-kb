{
  "name": "md-kb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:packages": "npm run build -w @skycell-ag/kb-core",
    "predev": "npm run build:packages",
    "dev": "vite",
    "prebuild": "npm run build:packages",
    "build": "vite build",
    "start": "tsx --env-file-if-exists=.env.local server/index.ts",
    "server:dev": "tsx watch --env-file-if-exists=.env.local server/index.ts",
    "db:migrate": "psql \"${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres}\" -v ON_ERROR_STOP=1 -f supabase/migrations.sql -c \"notify pgrst, 'reload schema';\"",
    "db:seed": "psql \"${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres}\" -v ON_ERROR_STOP=1 -f supabase/seed.sql",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "i18n:pull": "node --env-file-if-exists=.env.local scripts/i18n-pull.mjs",
    "i18n:push": "node --env-file-if-exists=.env.local scripts/i18n-push.mjs",
    "test": "vitest run",
    "pretypecheck": "npm run build:packages",
    "typecheck": "tsc --noEmit",
    "build:kb-react": "npm run build:packages && npm run build -w @skycell-ag/kb-react"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@skycell-ag/kb-core": "*",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.107.0",
    "@uiw/react-markdown-preview": "5.2.1",
    "@uiw/react-md-editor": "4.1.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "i18next": "26.3.3",
    "i18next-browser-languagedetector": "8.2.1",
    "multer": "2.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "react-icons": "5.6.0",
    "react-router-dom": "7.18.0",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "29.1.1",
    "oxlint": "1.69.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
