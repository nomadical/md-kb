# ── Supabase ────────────────────────────────────────────────────────────────
# Browser-exposed (Vite). Project Settings → API.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Where the app is served (used for auth redirects). Match how you run it.
VITE_SITE_URL=http://localhost:5173
# Base path the app is mounted at (default "/"). e.g. "/kb" if behind a prefix.
VITE_BASE_PATH=/

# Server-only — never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
PORT=8787

# ── Auth ──────────────────────────────────────────────────────────────────
# Email + password and magic-link work out of the box (configure SMTP in
# Supabase for magic-link delivery). OAuth providers are optional: enable them
# in the Supabase dashboard and list the ones to show here (comma-separated):
#   VITE_OAUTH_PROVIDERS=github,google
VITE_OAUTH_PROVIDERS=

# ── Ask-the-KB (optional, pgvector RAG) ─────────────────────────────────────
# Disabled by default (toggle in Admin → Settings). Point at any
# OpenAI-compatible endpoint (OpenAI, Ollama, LM Studio, …). The embedding
# column is vector(768) — the embeddings model must output 768 dimensions.
# EMBEDDINGS_URL=http://localhost:11434/v1
# EMBEDDINGS_MODEL=nomic-embed-text
# CHAT_URL=http://localhost:11434/v1
# CHAT_MODEL=llama3.1
# OPENAI_API_KEY=